---
import { ClientRouter } from "astro:transitions";

const {
  title = "Our Story",
  description = "A handwritten memorial site built with Astro.",
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preload" href="/fonts/Laura-Cursive-subset.woff2" as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
    <ClientRouter fallback="animate" />
    <script is:inline>
      // 只在首次加载（非 View Transitions 路由切换）时显示加载指示器
      if (!window.__pgLoaderDone) {
        const MAX_WAIT_MS = 5000; // 网络再差，最多等 5 秒

        const finish = () => {
          if (window.__pgLoaderDone) return;
          window.__pgLoaderDone = true;

          const loader = document.getElementById("pg-loader");
          if (!loader) return;

          loader.classList.add("pg-loader--done");
          loader.addEventListener(
            "transitionend",
            () => loader.remove(),
            { once: true },
          );
        };

        const timer = setTimeout(finish, MAX_WAIT_MS);

        document.fonts.ready.then(() => {
          clearTimeout(timer);
          // 双 rAF：确保浏览器已用新字体完成首帧绘制，再移除遮罩
          requestAnimationFrame(() => requestAnimationFrame(finish));
        });
      }
    </script>
    <style>
      #pg-loader {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f1e4d5;
        transition: opacity 500ms ease;
      }
      #pg-loader.pg-loader--done {
        opacity: 0;
        pointer-events: none;
      }
      .pg-loader__heart {
        color: #d9968c;
        font-size: 52px;
        line-height: 1;
        animation: pg-loader-pulse 1.3s ease-in-out infinite;
        font-family: serif;
      }
      @keyframes pg-loader-pulse {
        0%, 100% { transform: scale(1) rotate(-12deg); }
        50%       { transform: scale(1.22) rotate(-12deg); }
      }
    </style>
  </head>
  <body>
    <div id="pg-loader" aria-hidden="true">
      <span class="pg-loader__heart">♡</span>
    </div>
    <slot />
    <script>
      if (!window.__ourStoryTransitionImagesReady) {
        window.__ourStoryTransitionImagesReady = true;

        const preloadImage = (src, signal) =>
          new Promise((resolve) => {
            if (!src || signal?.aborted) {
              resolve();
              return;
            }

            const image = new Image();
            const finish = () => resolve();

            image.onload = async () => {
              try {
                await image.decode?.();
              } catch {
                // Decoding is a polish step; failed decode should never block navigation.
              }
              finish();
            };
            image.onerror = finish;
            image.src = src;
          });

        const warmNextPageImages = async (event) => {
          const nextDocument = event.newDocument;
          const nextUrl = event.to;

          if (!(nextDocument instanceof Document) || !(nextUrl instanceof URL)) {
            return;
          }

          const images = Array.from(
            nextDocument.querySelectorAll(
              ".hero-photo img, .photo-tile img, .small-photo img, .generated-couple, .generated-flower, .bottom-park-art",
            ),
          )
            .map((image) => image.getAttribute("src"))
            .filter(Boolean)
            .slice(0, 8)
            .map((src) => new URL(src, nextUrl).href);

          if (!images.length) {
            return;
          }

          await Promise.race([
            Promise.allSettled(images.map((src) => preloadImage(src, event.signal))),
            new Promise((resolve) => setTimeout(resolve, 850)),
          ]);
        };

        document.addEventListener("astro:before-preparation", (event) => {
          const originalLoader = event.loader;

          if (typeof originalLoader !== "function") {
            return;
          }

          event.loader = async () => {
            await originalLoader();

            if (!event.defaultPrevented && !event.signal?.aborted) {
              await warmNextPageImages(event);
            }
          };
        });
      }
    </script>
  </body>
</html>
