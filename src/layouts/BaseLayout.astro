---
import { ClientRouter } from "astro:transitions";

const {
  title = "Our Story",
  description = "A handwritten memorial site built with Astro.",
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link
      rel="preload"
      href="/fonts/Laura%20Cursive.otf"
      as="font"
      type="font/otf"
      crossorigin
    />
    <title>{title}</title>
    <ClientRouter fallback="animate" />
    <script is:inline>
      // 首次加载时立即在 <html> 上标记骨架屏状态，避免字体就绪前露出文字
      if (!window.__pgFontsReady) {
        document.documentElement.classList.add("fonts-loading");

        const MAX_WAIT_MS = 6000;

        const finish = () => {
          if (window.__pgFontsReady) return;
          window.__pgFontsReady = true;
          const html = document.documentElement;
          html.classList.remove("fonts-loading");
          html.classList.add("fonts-loaded");
        };

        const timer = setTimeout(finish, MAX_WAIT_MS);

        // 骨架屏把文字设为透明，浏览器会认为没有可见字形需要该字体，
        // 于是根本不去下载它，document.fonts.ready 立刻 resolve → 骨架屏提前移除、
        // 露出回退字体，随后 web 字体才加载并替换，造成字体闪烁。
        // 这里显式触发字体下载，并等待「该字体」真正就绪。
        const fontsReady =
          document.fonts && typeof document.fonts.load === "function"
            ? document.fonts
                .load('1em "Laura Cursive"')
                .catch(() => {})
                .then(() => document.fonts.ready)
            : Promise.resolve();

        fontsReady.then(() => {
          clearTimeout(timer);
          // 双 rAF：确保浏览器已用新字体完成首帧绘制，再移除骨架屏
          requestAnimationFrame(() => requestAnimationFrame(finish));
        });
      }
    </script>
  </head>
  <body>
    <slot />
    <script>
      if (!window.__ourStoryTransitionImagesReady) {
        window.__ourStoryTransitionImagesReady = true;

        const preloadImage = (src, signal) =>
          new Promise((resolve) => {
            if (!src || signal?.aborted) {
              resolve();
              return;
            }

            const image = new Image();
            const finish = () => resolve();

            image.onload = async () => {
              try {
                await image.decode?.();
              } catch {
                // Decoding is a polish step; failed decode should never block navigation.
              }
              finish();
            };
            image.onerror = finish;
            image.src = src;
          });

        const warmNextPageImages = async (event) => {
          const nextDocument = event.newDocument;
          const nextUrl = event.to;

          if (!(nextDocument instanceof Document) || !(nextUrl instanceof URL)) {
            return;
          }

          const images = Array.from(
            nextDocument.querySelectorAll(
              ".hero-photo img, .photo-tile img, .small-photo img, .generated-couple, .generated-flower, .bottom-park-art",
            ),
          )
            .map((image) => image.getAttribute("src"))
            .filter(Boolean)
            .slice(0, 8)
            .map((src) => new URL(src, nextUrl).href);

          if (!images.length) {
            return;
          }

          await Promise.race([
            Promise.allSettled(images.map((src) => preloadImage(src, event.signal))),
            new Promise((resolve) => setTimeout(resolve, 850)),
          ]);
        };

        document.addEventListener("astro:before-preparation", (event) => {
          const originalLoader = event.loader;

          if (typeof originalLoader !== "function") {
            return;
          }

          event.loader = async () => {
            await originalLoader();

            if (!event.defaultPrevented && !event.signal?.aborted) {
              await warmNextPageImages(event);
            }
          };
        });
      }
    </script>
  </body>
</html>
