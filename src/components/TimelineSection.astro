---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";

interface TimelineCard {
  entry: {
    data: {
      side: "left" | "right";
      tilt: string;
      images: string[];
      alt: string;
      date: string;
      title: string;
    };
  };
  Content: AstroComponentFactory;
}

interface Props {
  timelineCards: TimelineCard[];
}

const { timelineCards } = Astro.props;

// 堆叠时最多显示 3 张
const STACK_LIMIT = 3;
---

<section id="timeline" class="timeline-section">
  <h2>时间线<span>♡</span></h2>
  <div class="timeline-line" aria-hidden="true">
    <span class="node n1"></span>
    <span class="node n2"></span>
    <span class="node n3"></span>
  </div>

  {timelineCards.map(({ entry, Content }, index) => {
    const { images, alt, side, tilt, date, title } = entry.data;
    const stackImgs = images.slice(0, STACK_LIMIT);
    const hasStack = stackImgs.length > 1;

    const photoBlock = (tapeSide: "left" | "right") => (
      <div class={hasStack ? `photo-stack ${tilt}` : ""}>
        {stackImgs.map((src, i) => (
          <figure
            class={[
              "polaroid small-photo",
              !hasStack ? tilt : "",
              hasStack ? `stack-item stack-${i + 1}` : "",
            ].filter(Boolean).join(" ")}
            aria-hidden={i > 0 ? "true" : undefined}
          >
            {i === 0 && (
              <span class={`tape tape-corner-${tapeSide}`}></span>
            )}
            <img
              src={src}
              alt={i === 0 ? alt : ""}
              decoding="async"
              loading="lazy"
            />
            {i === 0 && <figcaption><span>♡</span></figcaption>}
          </figure>
        ))}
        {images.length > STACK_LIMIT && (
          <span class="stack-count" aria-label={`共 ${images.length} 张`}>
            +{images.length - STACK_LIMIT}
          </span>
        )}
      </div>
    );

    return (
      <article class={`event event-${side} event-${index + 1}`}>
        {side === "left" ? (
          <>
            {photoBlock("left")}
            <div class="memory-card">
              <time>{date}</time>
              <h3>{title} <span>♡</span></h3>
              <Content />
            </div>
          </>
        ) : (
          <>
            <div class="memory-card">
              <time>{date}</time>
              <h3>{title} <span>♡</span></h3>
              <Content />
            </div>
            {photoBlock("right")}
          </>
        )}
      </article>
    );
  })}

  <p class="future">
    未来的每一天，<br />
    都想和你一起度过。<span>♡</span>
  </p>
</section>
