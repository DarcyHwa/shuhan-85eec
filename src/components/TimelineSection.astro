---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";

interface TimelineCard {
  entry: {
    data: {
      side: "left" | "right";
      tilt: string;
      images: string[];
      alt: string;
      date: string;
      title: string;
    };
  };
  Content: AstroComponentFactory;
}

interface Props {
  timelineCards: TimelineCard[];
}

const { timelineCards } = Astro.props;

const STACK_LIMIT = 3;
---

<section id="timeline" class="timeline-section">
  <h2>时间线<span>♡</span></h2>
  <div class="timeline-line" aria-hidden="true">
    <span class="node n1"></span>
    <span class="node n2"></span>
    <span class="node n3"></span>
  </div>

  {timelineCards.map(({ entry, Content }, index) => {
    const { images, alt, side, tilt, date, title } = entry.data;
    const stackImgs = images.slice(0, STACK_LIMIT);
    const hasStack = images.length > 1;

    const photoBlock = (tapeSide: "left" | "right") => hasStack ? (
      <div
        class={`photo-stack ${tilt}`}
        data-lightbox
        data-images={JSON.stringify(images)}
        data-alt={alt}
        role="button"
        tabindex="0"
        aria-label={`查看「${title}」的 ${images.length} 张照片`}
      >
        {stackImgs.map((src, i) => (
          <figure
            class={`polaroid small-photo stack-item stack-${i + 1}`}
            aria-hidden={i > 0 ? "true" : undefined}
          >
            {i === 0 && <span class={`tape tape-corner-${tapeSide}`}></span>}
            <img src={src} alt={i === 0 ? alt : ""} decoding="async" loading="lazy" />
            {i === 0 && <figcaption><span>♡</span></figcaption>}
          </figure>
        ))}
        <span class="stack-count" aria-hidden="true">{images.length} 张</span>
      </div>
    ) : (
      <figure
        class={`polaroid small-photo ${tilt}`}
        data-lightbox
        data-images={JSON.stringify(images)}
        data-alt={alt}
        role="button"
        tabindex="0"
        aria-label={`查看「${title}」的照片`}
      >
        <span class={`tape tape-corner-${tapeSide}`}></span>
        <img src={stackImgs[0]} alt={alt} decoding="async" loading="lazy" />
        <figcaption><span>♡</span></figcaption>
      </figure>
    );

    return (
      <article class={`event event-${side} event-${index + 1}`}>
        {side === "left" ? (
          <>
            {photoBlock("left")}
            <div class="memory-card">
              <time>{date}</time>
              <h3>{title} <span>♡</span></h3>
              <Content />
            </div>
          </>
        ) : (
          <>
            <div class="memory-card">
              <time>{date}</time>
              <h3>{title} <span>♡</span></h3>
              <Content />
            </div>
            {photoBlock("right")}
          </>
        )}
      </article>
    );
  })}

  <p class="future">
    未来的每一天，<br />
    都想和你一起度过。<span>♡</span>
  </p>
</section>

{/* ── Lightbox 遮罩（全站一个，复用） ─────────────────────────────────────── */}
<div id="lightbox" class="lightbox" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-label="照片查看">
  <button class="lb-close" data-lb-close aria-label="关闭">&times;</button>
  <button class="lb-nav lb-prev" data-lb-prev aria-label="上一张">&#8249;</button>
  <figure class="lb-stage">
    <img class="lb-img" data-lb-img src="" alt="" />
    <figcaption class="lb-caption"><span class="lb-counter" data-lb-counter></span></figcaption>
  </figure>
  <button class="lb-nav lb-next" data-lb-next aria-label="下一张">&#8250;</button>
</div>

<script>
  function initLightbox() {
    const lb = document.getElementById("lightbox");
    if (!lb || lb.dataset.bound) return;
    lb.dataset.bound = "1";

    const imgEl = lb.querySelector<HTMLImageElement>("[data-lb-img]")!;
    const counterEl = lb.querySelector<HTMLElement>("[data-lb-counter]")!;
    const btnPrev = lb.querySelector<HTMLElement>("[data-lb-prev]")!;
    const btnNext = lb.querySelector<HTMLElement>("[data-lb-next]")!;
    const btnClose = lb.querySelector<HTMLElement>("[data-lb-close]")!;

    let images: string[] = [];
    let alt = "";
    let idx = 0;
    let lastTrigger: HTMLElement | null = null;

    const render = () => {
      imgEl.src = images[idx];
      imgEl.alt = images.length > 1 ? `${alt}（${idx + 1}）` : alt;
      counterEl.textContent =
        images.length > 1 ? `${idx + 1} / ${images.length}` : "";
      const multi = images.length > 1;
      btnPrev.hidden = !multi;
      btnNext.hidden = !multi;
      // 预加载相邻图片
      [idx + 1, idx - 1].forEach((n) => {
        const src = images[(n + images.length) % images.length];
        if (src) new Image().src = src;
      });
    };

    const open = (trigger: HTMLElement) => {
      images = JSON.parse(trigger.dataset.images ?? "[]");
      alt = trigger.dataset.alt ?? "";
      idx = 0;
      if (!images.length) return;
      lastTrigger = trigger;
      render();
      lb.hidden = false;
      lb.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      requestAnimationFrame(() => lb.classList.add("open"));
      btnClose.focus();
    };

    const close = () => {
      lb.classList.remove("open");
      document.body.style.overflow = "";
      lb.setAttribute("aria-hidden", "true");
      const done = () => {
        lb.hidden = true;
        lb.removeEventListener("transitionend", done);
      };
      lb.addEventListener("transitionend", done);
      lastTrigger?.focus();
    };

    const go = (delta: number) => {
      idx = (idx + delta + images.length) % images.length;
      render();
    };

    // 绑定所有触发器
    document.querySelectorAll<HTMLElement>("[data-lightbox]").forEach((el) => {
      if (el.dataset.lbBound) return;
      el.dataset.lbBound = "1";
      el.addEventListener("click", () => open(el));
      el.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          open(el);
        }
      });
    });

    btnClose.addEventListener("click", close);
    btnPrev.addEventListener("click", (e) => { e.stopPropagation(); go(-1); });
    btnNext.addEventListener("click", (e) => { e.stopPropagation(); go(1); });
    // 点击遮罩空白处关闭
    lb.addEventListener("click", (e) => {
      if (e.target === lb) close();
    });

    document.addEventListener("keydown", (e) => {
      if (lb.hidden) return;
      if (e.key === "Escape") close();
      else if (e.key === "ArrowRight") go(1);
      else if (e.key === "ArrowLeft") go(-1);
    });

    // 移动端左右滑动
    let touchX = 0;
    lb.addEventListener("touchstart", (e) => { touchX = e.touches[0].clientX; }, { passive: true });
    lb.addEventListener("touchend", (e) => {
      const dx = e.changedTouches[0].clientX - touchX;
      if (Math.abs(dx) > 45) go(dx < 0 ? 1 : -1);
    }, { passive: true });
  }

  initLightbox();
  document.addEventListener("astro:page-load", initLightbox);
</script>
