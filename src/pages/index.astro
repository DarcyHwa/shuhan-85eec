---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeHero from "../components/HomeHero.astro";
import ParkScene from "../components/ParkScene.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import TimelineSection from "../components/TimelineSection.astro";
import "../styles/global.css";

const timelineEntries = (await getCollection("timeline")).sort(
  (a, b) => a.data.order - b.data.order,
);

const timelineCards = await Promise.all(
  timelineEntries.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);
---

<BaseLayout title="LiuShuhan & HuaSong" description="记录我们一路走来的小小纪念站。">
  <main class="page-shell" aria-label="LiuShuhan & HuaSong love journal page">
    <section class="artboard">
      <div class="paper-noise"></div>
      <SiteHeader active="home" />
      <HomeHero />
      <TimelineSection timelineCards={timelineCards} />
      <ParkScene />
      <SiteFooter />
    </section>
  </main>
</BaseLayout>
